{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "jest"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {},
  "overrides": [
    {
      "files": ["tests/**/*.test.ts"],
      "rules": {
        "unicorn/consistent-function-scoping": "off"
      }
    }
  ],
  "env": {
    "builtin": true,
    "node": true
  }
}
