{
  "name": "pi-agy-provider",
  "version": "0.1.0",
  "description": "[WIP/PoC] Google Gemini provider for pi — access Gemini models through Google's OpenAI-compatible API. For stable Antigravity OAuth, use @yofriadi/pi-antigravity-oauth.",
  "keywords": [
    "agy",
    "ai",
    "antigravity",
    "gemini",
    "google",
    "llm",
    "pi",
    "pi-coding-agent",
    "pi-package",
    "provider"
  ],
  "homepage": "https://github.com/jellydn/pi-agy-provider#readme",
  "bugs": {
    "url": "https://github.com/jellydn/pi-agy-provider/issues"
  },
  "license": "MIT",
  "author": "jellydn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jellydn/pi-agy-provider.git"
  },
  "files": [
    "src",
    "tests",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bash tests/e2e/smoke.sh",
    "lint": "oxlint --config .oxlintrc.json src/ tests/",
    "format": "oxfmt --write src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "typecheck": "tsc",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate",
    "release": "bumpp --commit --push --tag",
    "release:patch": "bumpp --commit --push --tag patch",
    "release:minor": "bumpp --commit --push --tag minor",
    "release:major": "bumpp --commit --push --tag major",
    "pub": "npm publish"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^26.0.1",
    "all-contributors-cli": "^6.26.1",
    "bumpp": "^11.1.0",
    "np": "^11.2.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=22"
  },
  "np": {
    "branch": "main",
    "testScript": "npm test",
    "yarn": false,
    "pnpm": false,
    "releaseDraft": true
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
